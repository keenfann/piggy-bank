{
  "name": "piggy-bank",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\" \"npm run dev:chrome\"",
    "dev:web": "vite --host 0.0.0.0 --port 5173 --strictPort",
    "dev:server": "tsx watch --exclude \"db/**\" --exclude \"uploads/**\" server/index.ts",
    "dev:chrome": "sleep 2 && open -a \"Google Chrome\" http://localhost:5173",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.node.json && mkdir -p build/server/migrations && cp -R server/migrations/. build/server/migrations",
    "start": "node build/server/index.js",
    "start:e2e": "node build/server/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "csv-parse": "^6.1.0",
    "express": "5.2.1",
    "express-session": "^1.18.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "overrides": {
    "router": "2.2.0",
    "path-to-regexp": "8.4.0"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "jsdom": "^28.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  }
}
